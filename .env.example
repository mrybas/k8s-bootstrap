# =============================================================================
# K8s Bootstrap — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your deployment.
#
# Variables prefixed with K8S_BOOTSTRAP_ map to backend Settings (pydantic).
# Variables without prefix are used by docker-compose.prod.yml.

# -----------------------------------------------------------------------------
# Production Compose (docker-compose.prod.yml)
# -----------------------------------------------------------------------------

# Your domain for the public-facing frontend
DOMAIN=k8s-bootstrap.example.com

# GitHub Container Registry image coordinates
GITHUB_REPOSITORY=your-org/k8s-bootstrap

# Image tag — commit SHA or release tag
VERSION=latest

# -----------------------------------------------------------------------------
# Backend — API Settings
# -----------------------------------------------------------------------------

# Enable debug mode (disable in production)
K8S_BOOTSTRAP_DEBUG=false

# CORS allowed origins (comma-separated, used by FastAPI CORSMiddleware)
# K8S_BOOTSTRAP_CORS_ORIGINS=["https://k8s-bootstrap.example.com"]

# Path to component definitions (rarely needs changing)
# K8S_BOOTSTRAP_DEFINITIONS_PATH=/app/definitions/components

# -----------------------------------------------------------------------------
# Backend — Session / Token Storage
# -----------------------------------------------------------------------------

# Directory for temporary bootstrap session files
# K8S_BOOTSTRAP_STORAGE_DIR=/tmp/k8s-bootstrap-sessions

# Bootstrap token time-to-live in minutes (default: 60)
# K8S_BOOTSTRAP_TOKEN_TTL_MINUTES=60

# Session TTL in minutes (used by Settings)
# K8S_BOOTSTRAP_SESSION_TTL_MINUTES=60
